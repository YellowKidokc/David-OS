{
  "integrations": [
    {
      "integration_id": "nas-primary",
      "label": "Primary NAS",
      "kind": "storage",
      "status": "planned",
      "base_url": "http://192.168.2.50",
      "capabilities": ["file_index", "archive", "sync_target"],
      "auth": {
        "type": "manual",
        "secret_ref": "NAS_API_TOKEN"
      },
      "metadata": {
        "notes": "Use for shared folders, media archives, and long-term storage."
      }
    },
    {
      "integration_id": "syncthing",
      "label": "Syncthing",
      "kind": "sync",
      "status": "planned",
      "base_url": "http://127.0.0.1:8384",
      "capabilities": ["folder_sync", "device_status", "sync_status"],
      "auth": {
        "type": "manual",
        "secret_ref": "SYNCTHING_API_KEY"
      },
      "metadata": {
        "notes": "Use for LAN/device file replication after files are tagged and routed."
      }
    },
    {
      "integration_id": "cloudflare-r2",
      "label": "Cloudflare R2",
      "kind": "object_storage",
      "status": "planned",
      "base_url": "https://api.cloudflare.com/client/v4",
      "capabilities": ["upload", "public_url", "manifest_publish"],
      "auth": {
        "type": "manual",
        "secret_ref": "CLOUDFLARE_API_TOKEN"
      },
      "metadata": {
        "notes": "Use for public media, transcripts, and website assets."
      }
    },
    {
      "integration_id": "autohotkey-local",
      "label": "AutoHotkey Local Bridge",
      "kind": "desktop_bridge",
      "status": "active",
      "base_url": "http://127.0.0.1",
      "capabilities": ["hotkeys", "type_text", "click_buttons", "clipboard", "window_follow"],
      "auth": {
        "type": "none"
      },
      "metadata": {
        "notes": "AHK acts as hands for local apps while the hub stays the brain."
      }
    }
  ]
}
