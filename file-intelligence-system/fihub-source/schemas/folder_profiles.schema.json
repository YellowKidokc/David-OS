{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/file-intelligence-hub/folder_profiles.schema.json",
  "title": "File Intelligence Hub Folder Profiles",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "defaults": {"$ref": "#/$defs/profile"},
    "profiles": {
      "type": "array",
      "items": {"$ref": "#/$defs/profileWithPath"}
    }
  },
  "required": ["profiles"],
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {"type": "string"},
        "folder_role": {"type": "string"},
        "watch_enabled": {"type": "boolean"},
        "review_only": {"type": "boolean"},
        "protected": {"type": "boolean"},
        "parser_preferences": {"type": "array", "items": {"type": "string"}},
        "routing_hints": {"type": "object"},
        "thresholds": {"type": "object", "additionalProperties": {"type": "number"}}
      }
    },
    "profileWithPath": {
      "allOf": [
        {"$ref": "#/$defs/profile"},
        {"required": ["path"]}
      ]
    }
  }
}
